{
  "name": "wuxiadreams",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "wrangler types && astro dev --port 5173",
    "build": "astro build",
    "preview": "astro preview --port 5173",
    "db:gen": "drizzle-kit generate",
    "db:studio": "LOCAL_DB_PATH=$(ls -t .wrangler/state/v3/d1/miniflare-D1DatabaseObject/*.sqlite | grep -v metadata.sqlite | head -n 1) drizzle-kit studio --config drizzle.config.ts",
    "db:push:local": "wrangler d1 migrations apply wuxiadreams --local",
    "db:push:prod": "wrangler d1 migrations apply wuxiadreams --remote",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/react": "^5.0.3",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@better-auth/drizzle-adapter": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.2",
    "@nanostores/react": "^1.1.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.4",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "easymde": "^2.20.0",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.7",
    "nanostores": "^1.2.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-simplemde-editor": "^5.2.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "use-debounce": "^10.1.1",
    "vaul": "^1.1.2",
    "wrangler": "^4.81.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260408.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/eslint-plugin-query": "^5.97.0",
    "drizzle-kit": "^0.31.10",
    "postgres": "^3.4.9"
  },
  "overrides": {
    "vite": "^7"
  }
}