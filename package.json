{
  "name": "wuxiadreams.com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "wrangler types && astro dev --port 5173",
    "build": "astro build",
    "preview": "astro preview --port 5173",
    "db:gen": "drizzle-kit generate",
    "db:studio": "LOCAL_DB_PATH=$(ls -t .wrangler/state/v3/d1/miniflare-D1DatabaseObject/*.sqlite | grep -v metadata.sqlite | head -n 1) drizzle-kit studio --config drizzle.config.ts",
    "db:push:local": "wrangler d1 execute wuxiadreams --local --file=$(ls -t drizzle/*.sql | head -n 1)",
    "db:push:prod": "wrangler d1 execute wuxiadreams --remote --file=$(ls -t drizzle/*.sql | head -n 1)",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/react": "^5.0.3",
    "@better-auth/drizzle-adapter": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.4",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.81.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260408.1",
    "drizzle-kit": "^0.31.10"
  },
  "overrides": {
    "vite": "^7"
  }
}