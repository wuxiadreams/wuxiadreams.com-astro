---
import { env } from "cloudflare:workers";
import { AuthDialog } from "./auth-dialog";
import { UserMenu } from "./user-menu";
import { MobileMenu } from "./mobile-menu";

const { currentPath = "/" } = Astro.props;
const user = Astro.locals.user;
const adminEmails = (env.ADMIN_EMAILS ?? "").split(",");
const isAdmin = user ? adminEmails.includes(user.email || "") : false;

const navItems = [
  {
    href: "/novels",
    label: "Browse",
    subItems: [
      { href: "/novels", label: "All Novels" },
      { href: "/rankings", label: "Rankings" },
    ],
  },
  { href: "/genres", label: "Genres" },
  { href: "/authors", label: "Authors" },
  { href: "/library", label: "Library" },
];

const isActive = (href: string, exact: boolean = false) => {
  if (href === "/") return currentPath === "/";
  if (exact) return currentPath === href;
  return currentPath.startsWith(href);
};
---

<header
  class="sticky top-0 z-40 border-b border-border/60 bg-background/70 backdrop-blur"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-4 px-4">
    <a href="/" class="group flex items-center gap-3">
      <img
        src="/logo.png"
        alt="Wuxia Dreams"
        width="32"
        height="32"
        class="h-8 w-8 rounded-md ring-1 ring-border/70"
        loading="eager"
      />
      <div class="leading-tight">
        <div class="text-sm font-semibold tracking-tight text-foreground">
          Wuxia Dreams
        </div>
        <div class="text-[11px] tracking-[0.1em] text-muted-foreground">
          Free Novels Online
        </div>
      </div>
    </a>

    <nav class="ml-6 hidden items-center gap-1 md:flex">
      {
        navItems.map((item) =>
          item.subItems ? (
            <div class="relative group">
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "inline-flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition",
                  isActive(item.href) ||
                  item.subItems.some((sub) => isActive(sub.href))
                    ? "bg-muted text-foreground"
                    : "text-muted-foreground hover:bg-muted/70 hover:text-foreground",
                ]}
              >
                {item.label}
                <svg
                  class="h-3.5 w-3.5 opacity-50 transition-transform duration-200 group-hover:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </a>
              <div class="absolute left-0 top-full hidden pt-2 group-hover:block">
                <div class="w-48 rounded-xl border border-border/70 bg-background/95 p-1.5 shadow-xl backdrop-blur">
                  {item.subItems.map((sub) => (
                    <a
                      href={sub.href}
                      class:list={[
                        "block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors",
                        isActive(sub.href, true)
                          ? "bg-primary text-primary-foreground"
                          : "text-muted-foreground hover:bg-muted hover:text-foreground",
                      ]}
                    >
                      {sub.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "rounded-lg px-3 py-2 text-sm font-medium transition",
                isActive(item.href)
                  ? "bg-muted text-foreground"
                  : "text-muted-foreground hover:bg-muted/70 hover:text-foreground",
              ]}
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <form action="/novels" method="get" class="hidden lg:block">
        <label class="group relative block">
          <input
            name="q"
            placeholder="Search titles / authors / tags"
            class="h-10 w-[22rem] rounded-xl border border-input bg-background/60 px-3 pr-10 text-sm text-foreground shadow-sm transition placeholder:text-muted-foreground/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50"
          />
          <div
            class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-muted-foreground"
          >
            ⌘K
          </div>
        </label>
      </form>

      <button
        type="button"
        data-theme-toggle
        class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border/60 bg-background/60 text-foreground shadow-sm transition hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50"
        aria-label="Toggle theme"
      >
        <span class="sr-only">Toggle theme</span>
        <svg
          class="h-4 w-4 text-muted-foreground dark:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
        <svg
          class="hidden h-4 w-4 text-muted-foreground dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="M4.93 4.93l1.41 1.41"></path>
          <path d="M17.66 17.66l1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="M6.34 17.66l-1.41 1.41"></path>
          <path d="M19.07 4.93l-1.41 1.41"></path>
        </svg>
      </button>

      {
        user ? (
          <UserMenu
            client:load
            isAdmin={isAdmin}
            user={{
              id: user.id,
              name: user.name,
              email: user.email,
              image: user.image,
            }}
          />
        ) : (
          <AuthDialog client:load />
        )
      }

      <MobileMenu
        client:load
        navItems={navItems}
        currentPath={currentPath}
        user={user}
        isAdmin={isAdmin}
      />
    </div>
  </div>
</header>

<script>
  import { authClient } from "@/lib/auth-client";

  const logoutBtns = document.querySelectorAll("[data-logout-btn]");
  logoutBtns.forEach((btn) => {
    btn.addEventListener("click", async () => {
      await authClient.signOut();
      window.location.reload();
    });
  });
</script>

<script is:inline>
  (() => {
    const buttons = document.querySelectorAll("[data-theme-toggle]");
    if (!buttons.length) return;

    const root = document.documentElement;

    for (const btn of buttons) {
      btn.addEventListener("click", () => {
        const nextIsDark = root.classList.toggle("dark");
        const next = nextIsDark ? "dark" : "light";
        root.style.colorScheme = next;
        try {
          localStorage.setItem("theme", next);
        } catch {}
      });
    }
  })();
</script>
