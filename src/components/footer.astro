---
import { AuthDialog } from "@/components/auth-dialog";
import { Image } from "astro:assets";
import FooterDynamic from "./footer-dynamic.astro";

const year = new Date().getFullYear();
const columns = [
  {
    title: "Explore",
    links: [
      { href: "/novels", label: "Novels" },
      { href: "/rankings", label: "Rankings" },
      { href: "/authors", label: "Authors" },
      { href: "/genres", label: "Genres" },
      { href: "/tags", label: "Tags" },
    ],
  },
  {
    title: "Teams",
    links: [
      { href: "/about", label: "About" },
      { href: "mailto:wuxiadreams@gmail.com", label: "Contact" },
      { href: "#", label: "Feedback" },
    ],
  },
];
---

<footer class="border-t border-border/60 bg-background">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-10 md:grid-cols-[1.2fr_2fr]">
      <div>
        <div class="flex items-center gap-3">
          <Image
            src="/logo.png"
            alt="Wuxia Dreams"
            width={36}
            height={36}
            class="h-9 w-9 rounded-md ring-1 ring-border/70"
            loading="lazy"
          />
          <div>
            <div class="text-base font-semibold tracking-tight">
              Wuxia Dreams
            </div>
            <div class="text-xs tracking-[0.22em] text-muted-foreground">
              READ · TRACK · DISCOVER
            </div>
          </div>
        </div>

        <p class="mt-4 max-w-sm text-sm leading-relaxed text-muted-foreground">
          A focused fiction hub built for discovery and tracking. Find your next
          read fast, then keep your progress under control.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          <FooterDynamic server:defer>
            <AuthDialog
              slot="fallback"
              client:only
              triggerText="Sign in / Start tracking"
              triggerClassName="inline-flex h-10 cursor-pointer items-center justify-center rounded-xl bg-primary px-4 text-sm font-semibold text-primary-foreground shadow-sm transition hover:bg-primary/90"
            />
          </FooterDynamic>
          <a
            href="/novels"
            class="inline-flex h-10 items-center justify-center rounded-xl border border-border/70 bg-background px-4 text-sm font-semibold text-foreground shadow-sm transition hover:bg-muted"
          >
            Browse novels
          </a>
        </div>
      </div>

      <div class="grid gap-8 sm:grid-cols-3">
        {
          columns.map((col) => (
            <div>
              <div class="text-sm font-semibold text-foreground">
                {col.title}
              </div>
              <div class="mt-3 grid gap-2">
                {col.links.map((link) => (
                  <a
                    href={link.href}
                    class="text-sm text-muted-foreground transition hover:text-foreground"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-3 border-t border-border/60 pt-6 text-sm text-muted-foreground md:flex-row md:items-center md:justify-between"
    >
      <div>© {year} Wuxia Dreams. All rights reserved.</div>
      <div class="flex flex-wrap gap-x-4 gap-y-2">
        <a href="/privacy-policy" class="hover:text-foreground">Privacy</a>
        <a href="/terms-of-service" class="hover:text-foreground">Terms</a>
        <a href="/dmca" class="hover:text-foreground">DMCA</a>
      </div>
    </div>
  </div>
</footer>
