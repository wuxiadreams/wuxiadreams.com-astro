---
import { env } from "cloudflare:workers";
import { AuthDialog } from "./auth-dialog";
import { UserMenu } from "./user-menu";
import { MobileMenu } from "./mobile-menu";

const { currentPath = "/" } = Astro.props;
const user = Astro.locals.user;
const adminEmails = (env.ADMIN_EMAILS ?? "").split(",");
const isAdmin = user ? adminEmails.includes(user.email || "") : false;

const { navItems } = Astro.props;

if (user) {
  Astro.response.headers.set(
    "Cache-Control",
    "private, no-cache, no-store, must-revalidate",
  );
} else {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=60, s-maxage=31536000, stale-while-revalidate=60",
  );
}
---

<div class="flex-1 flex items-center justify-end gap-2">
  <form action="/novels" method="get" class="hidden lg:block">
    <label class="group relative flex items-center justify-end gap-2">
      <input
        name="q"
        placeholder="Search titles / authors / tags"
        class="h-10 w-80 rounded-xl border border-input bg-background/60 px-3 pr-10 text-sm text-foreground shadow-sm transition placeholder:text-muted-foreground/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50"
      />
      <div
        class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-muted-foreground"
      >
        ⌘K
      </div>
    </label>
  </form>

  <button
    type="button"
    data-theme-toggle
    class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border/60 bg-background/60 text-foreground shadow-sm transition hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50"
    aria-label="Toggle theme"
  >
    <span class="sr-only">Toggle theme</span>
    <svg
      class="h-4 w-4 text-muted-foreground dark:hidden"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
    </svg>
    <svg
      class="hidden h-4 w-4 text-muted-foreground dark:block"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="M4.93 4.93l1.41 1.41"></path>
      <path d="M17.66 17.66l1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="M6.34 17.66l-1.41 1.41"></path>
      <path d="M19.07 4.93l-1.41 1.41"></path>
    </svg>
  </button>

  {
    user ? (
      <UserMenu
        client:load
        isAdmin={isAdmin}
        user={{
          id: user.id,
          name: user.name,
          email: user.email,
          image: user.image,
        }}
      />
    ) : (
      <AuthDialog client:load />
    )
  }

  <MobileMenu
    client:only
    navItems={navItems}
    currentPath={currentPath}
    user={user}
    isAdmin={isAdmin}
  />
</div>

<script is:inline>
  if (typeof window.setupThemeToggle === "undefined") {
    window.setupThemeToggle = () => {
      function handleThemeClick(e) {
        const btn = e.target.closest("[data-theme-toggle]");
        if (!btn) return;

        const root = document.documentElement;
        const nextIsDark = root.classList.toggle("dark");
        const next = nextIsDark ? "dark" : "light";
        root.style.colorScheme = next;

        try {
          localStorage.setItem("theme", next);
        } catch {}
      }

      document.removeEventListener("click", handleThemeClick);
      document.addEventListener("click", handleThemeClick);
    };
  }

  // 1. 首次加载运行
  window.setupThemeToggle();

  // 2. 每次 View Transitions 切换页面后重新运行
  // 确保新页面的 root 状态和事件逻辑正确
  document.addEventListener("astro:page-load", window.setupThemeToggle);
</script>
