---
import Layout from "@/layouts/layout.astro";
---

<Layout title="Sign in — Wuxia Dreams">
  <main class="login-page">
    <section class="login-card">
      <p class="eyebrow">WUXIA DREAMS</p>
      <h1>Welcome back</h1>
      <p class="subtitle">Sign in to continue.</p>

      <form id="login-form" class="login-form">
        <label class="field">
          <span>Email</span>
          <input
            type="email"
            name="email"
            required
            placeholder="name@example.com"
          />
        </label>

        <label class="field">
          <span>Password</span>
          <input
            type="password"
            name="password"
            required
            placeholder="Enter your password"
          />
        </label>

        <button type="submit" class="submit-btn">Sign in</button>
      </form>

      <p id="message" class="message"></p>

      <p class="footer-link">
        <a href="/">Back to home</a>
      </p>
    </section>
  </main>
</Layout>

<script>
  import { authClient } from "@/lib/auth-client";

  const form = document.getElementById("login-form") as HTMLFormElement;
  const message = document.getElementById("message")!;
  const submitBtn = form?.querySelector(".submit-btn") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;

    message.textContent = "";
    message.className = "message";
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Signing in...";
    }

    try {
      const { error } = await authClient.signIn.email({
        email,
        password,
        callbackURL: "/admin/users",
        fetchOptions: {
          throw: false,
          onError(ctx) {
            console.log("Sign-in failed:", ctx.error);
          },
        },
      });

      if (error) {
        if (
          error.status === 401 ||
          error.code === "INVALID_EMAIL_OR_PASSWORD"
        ) {
          message.textContent = "Invalid email or password.";
        } else {
          message.textContent = `Sign-in failed: ${error.message || "Something went wrong."}`;
        }
        message.className = "message error";

        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = "Sign in";
        }
      } else {
        message.textContent = "Signed in. Redirecting...";
        message.className = "message success";

        window.location.href = "/admin/users";
      }
    } catch (err) {
      console.error("Request error:", err);
      message.textContent = "Sign-in failed: Network or server error.";
      message.className = "message error";

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Sign in";
      }
    }
  });
</script>

<style>
  .login-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 28px;
    background:
      radial-gradient(
        1200px 600px at 5% -5%,
        rgba(255, 208, 112, 0.2),
        transparent 55%
      ),
      radial-gradient(
        900px 500px at 110% 100%,
        rgba(122, 162, 255, 0.22),
        transparent 55%
      ),
      linear-gradient(160deg, #0b1220 0%, #101b32 45%, #0f172a 100%);
  }

  .login-card {
    width: min(100%, 420px);
    border-radius: 20px;
    padding: 32px 28px;
    color: #e2e8f0;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(15, 23, 42, 0.72);
    box-shadow: 0 24px 60px rgba(2, 6, 23, 0.55);
    backdrop-filter: blur(10px);
  }

  .eyebrow {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.24em;
    color: #93c5fd;
    text-align: center;
  }

  h1 {
    margin: 10px 0 8px;
    font-size: 34px;
    line-height: 1.15;
    color: #f8fafc;
    text-align: center;
  }

  .subtitle {
    margin: 0 0 24px;
    color: #cbd5e1;
    text-align: center;
  }

  .login-form {
    display: grid;
    gap: 16px;
  }

  .field {
    display: grid;
    gap: 8px;
  }

  .field span {
    font-size: 14px;
    color: #cbd5e1;
  }

  .field input {
    border: 1px solid rgba(100, 116, 139, 0.7);
    border-radius: 12px;
    padding: 11px 12px;
    background: rgba(15, 23, 42, 0.78);
    color: #f8fafc;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .field input::placeholder {
    color: #64748b;
  }

  .field input:focus {
    outline: none;
    border-color: #60a5fa;
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.25);
  }

  .submit-btn {
    margin-top: 8px;
    border: 0;
    border-radius: 12px;
    padding: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #082f49;
    background: linear-gradient(135deg, #fde68a, #93c5fd 58%, #7dd3fc);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      filter 0.15s ease;
  }

  .submit-btn:hover {
    filter: brightness(1.04);
    transform: translateY(-1px);
  }

  .message {
    margin: 14px 0 0;
    font-size: 14px;
    text-align: center;
    min-height: 20px;
    color: #cbd5e1;
  }

  .message.error {
    color: #fca5a5;
  }

  .message.success {
    color: #86efac;
  }

  .footer-link {
    margin: 20px 0 0;
    text-align: center;
    font-size: 14px;
    color: #94a3b8;
  }

  .footer-link a {
    color: #60a5fa;
    text-decoration: none;
    font-weight: 500;
  }

  .footer-link a:hover {
    text-decoration: underline;
  }
</style>
