---
import Layout from "@/layouts/layout.astro";
import { env } from "cloudflare:workers";
import { drizzle } from "drizzle-orm/d1";
import { desc } from "drizzle-orm";
import * as schema from "@/db/schema";

const db = drizzle(env.DB, { schema });

// Fetch top 10 novels by views
const topViewed = await db.query.novel.findMany({
  orderBy: [desc(schema.novel.views)],
  limit: 10,
});

// Fetch top 10 novels by score
const topRated = await db.query.novel.findMany({
  orderBy: [desc(schema.novel.score)],
  limit: 10,
});

const rankings = [
  {
    title: "Most Viewed",
    description: "The most popular novels right now",
    data: topViewed,
    valueKey: "views",
    valueLabel: "views",
  },
  {
    title: "Highest Rated",
    description: "Critically acclaimed by readers",
    data: topRated,
    valueKey: "score",
    valueLabel: "rating",
  },
];

// R2
const r2Domain = env.R2_DOMAIN;
---

<Layout title="Rankings — Wuxia Dreams">
  <main class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight">Rankings</h1>
      <p class="mt-2 text-muted-foreground">
        Discover the most popular and highly rated novels in our library.
      </p>
    </div>

    <div class="grid gap-10 md:grid-cols-2">
      {
        rankings.map((rank) => (
          <section class="rounded-3xl border border-border/70 bg-card/40 p-6 shadow-sm backdrop-blur">
            <div class="mb-6">
              <h2 class="text-xl font-bold tracking-tight">{rank.title}</h2>
              <p class="text-sm text-muted-foreground">{rank.description}</p>
            </div>

            <div class="grid gap-3">
              {rank.data.map((novel, index) => (
                <a
                  href={`/novel/${novel.slug}`}
                  class="group flex items-center gap-4 overflow-hidden rounded-2xl border border-border/50 bg-background/50 p-3 transition hover:bg-muted/80 hover:shadow-sm"
                >
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-muted font-bold text-muted-foreground group-hover:bg-primary group-hover:text-primary-foreground transition-colors">
                    {index + 1}
                  </div>

                  <div class="h-16 w-12 shrink-0 overflow-hidden rounded-md bg-muted">
                    {novel.cover ? (
                      <img
                        src={`https://${r2Domain}/${novel.cover}`}
                        alt={novel.title}
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="h-full w-full bg-muted/80" />
                    )}
                  </div>

                  <div class="flex flex-1 flex-col min-w-0">
                    <h3 class="truncate font-semibold text-foreground group-hover:text-primary transition-colors">
                      {novel.title}
                    </h3>
                    <div class="mt-1 flex items-center gap-2 text-xs text-muted-foreground">
                      <span>
                        {rank.valueKey === "score"
                          ? `${novel.score.toFixed(1)} ${rank.valueLabel}`
                          : `${novel.views.toLocaleString()} ${rank.valueLabel}`}
                      </span>
                      <span>•</span>
                      <span class="truncate">{novel.status}</span>
                    </div>
                  </div>
                </a>
              ))}

              {rank.data.length === 0 && (
                <div class="py-8 text-center text-sm text-muted-foreground">
                  No data available yet.
                </div>
              )}
            </div>
          </section>
        ))
      }
    </div>
  </main>
</Layout>
