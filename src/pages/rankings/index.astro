---
import Layout from "@/layouts/layout.astro";
import RankingSection from "@/components/ranking-section.astro";
import { RANK_TYPE } from "@/lib/constants";
---

<Layout
  title="Novel Rankings — Wuxia Dreams"
  description="Discover the most popular, trending, and highly rated novels across our entire library. Updated regularly."
>
  <main class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-16 text-center max-w-2xl mx-auto">
      <h1
        class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl"
      >
        Rankings
      </h1>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        Discover the most popular, trending, and highly rated novels across our
        entire library. Updated regularly.
      </p>
    </div>

    {/* 顶部三个核心榜单，三列布局 */}
    <div class="grid gap-10 md:grid-cols-2 xl:grid-cols-3 mb-16">
      <section
        class="rounded-3xl border border-border/70 bg-linear-to-b from-card/80 to-card/20 p-6 shadow-sm backdrop-blur-xl transition-all hover:shadow-lg"
      >
        <RankingSection type={RANK_TYPE.WEEKLY} server:defer>
          <div
            slot="fallback"
            class="flex h-96 items-center justify-center text-muted-foreground"
          >
            Loading weekly rankings...
          </div>
        </RankingSection>
      </section>

      <section
        class="rounded-3xl border border-border/70 bg-gradient-to-b from-card/80 to-card/20 p-6 shadow-sm backdrop-blur-xl transition-all hover:shadow-lg"
      >
        <RankingSection type={RANK_TYPE.MONTHLY} server:defer>
          <div
            slot="fallback"
            class="flex h-96 items-center justify-center text-muted-foreground"
          >
            Loading monthly rankings...
          </div>
        </RankingSection>
      </section>

      <section
        class="rounded-3xl border border-border/70 bg-gradient-to-b from-card/80 to-card/20 p-6 shadow-sm backdrop-blur-xl transition-all hover:shadow-lg"
      >
        <RankingSection type={RANK_TYPE.RISING_STAR} server:defer>
          <div
            slot="fallback"
            class="flex h-96 items-center justify-center text-muted-foreground"
          >
            Loading rising stars...
          </div>
        </RankingSection>
      </section>
    </div>

    {/* 分隔线 */}
    <div class="my-16 flex items-center justify-center">
      <div class="h-px w-full max-w-xs bg-border"></div>
      <div
        class="mx-4 text-xs font-semibold uppercase tracking-widest text-muted-foreground"
      >
        More Rankings
      </div>
      <div class="h-px w-full max-w-xs bg-border"></div>
    </div>

    {/* 下方三个榜单，两列或三列布局 */}
    <div class="grid gap-10 md:grid-cols-2 xl:grid-cols-3">
      <section
        class="rounded-2xl border border-border/40 bg-card/10 p-5 backdrop-blur transition-all hover:bg-card/30"
      >
        <RankingSection type={RANK_TYPE.VIEW} server:defer>
          <div
            slot="fallback"
            class="flex h-64 items-center justify-center text-muted-foreground text-sm"
          >
            Loading...
          </div>
        </RankingSection>
      </section>

      <section
        class="rounded-2xl border border-border/40 bg-card/10 p-5 backdrop-blur transition-all hover:bg-card/30"
      >
        <RankingSection type={RANK_TYPE.BOOKMARK} server:defer>
          <div
            slot="fallback"
            class="flex h-64 items-center justify-center text-muted-foreground text-sm"
          >
            Loading...
          </div>
        </RankingSection>
      </section>

      <section
        class="rounded-2xl border border-border/40 bg-card/10 p-5 backdrop-blur transition-all hover:bg-card/30 md:col-span-2 xl:col-span-1"
      >
        <RankingSection type={RANK_TYPE.HIGH_RATED} server:defer>
          <div
            slot="fallback"
            class="flex h-64 items-center justify-center text-muted-foreground text-sm"
          >
            Loading...
          </div>
        </RankingSection>
      </section>
    </div>
  </main>
</Layout>
