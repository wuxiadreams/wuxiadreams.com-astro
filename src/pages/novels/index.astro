---
import Layout from "@/layouts/layout.astro";
import { env } from "cloudflare:workers";
import { drizzle } from "drizzle-orm/d1";
import { like, count, desc, or, eq, and } from "drizzle-orm";
import * as schema from "@/db/schema";

const db = drizzle(env.DB, { schema });

const url = new URL(Astro.request.url);
const currentPage = parseInt(url.searchParams.get("page") || "1");
const searchQuery = url.searchParams.get("q") || "";
const pageSize = 20;

let searchClause = undefined;
if (searchQuery) {
  searchClause = or(
    like(schema.novel.title, `%${searchQuery}%`),
    like(schema.novel.titleAlt, `%${searchQuery}%`),
  );
}

const whereClause = and(eq(schema.novel.published, true), searchClause);

const [{ value: totalNovels }] = await db
  .select({ value: count() })
  .from(schema.novel)
  .where(whereClause);

const novels = await db.query.novel.findMany({
  where: whereClause,
  orderBy: [desc(schema.novel.createdAt)],
  limit: pageSize,
  offset: (currentPage - 1) * pageSize,
});

const totalPages = Math.max(1, Math.ceil(totalNovels / pageSize));

// Generate pagination links
const getPageUrl = (page: number) => {
  const newUrl = new URL(url);
  newUrl.searchParams.set("page", page.toString());
  return newUrl.pathname + newUrl.search;
};

// R2
const r2Domain = env.R2_DOMAIN;
---

<Layout title="Browse Novels — Wuxia Dreams">
  <main class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight">All Novels</h1>
      <p class="mt-2 text-muted-foreground">
        Browse our entire collection of wuxia, xianxia, and fantasy novels.
      </p>
    </div>

    <div
      class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
    >
      <form action="/novels" method="get" class="w-full sm:max-w-md">
        <label class="relative block">
          <input
            name="q"
            value={searchQuery}
            placeholder="Search by title..."
            class="h-10 w-full rounded-xl border border-input bg-background/60 px-4 pr-12 text-sm shadow-sm transition placeholder:text-muted-foreground/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50"
          />
          <button
            type="submit"
            class="absolute right-2 top-1/2 flex h-6 w-6 -translate-y-1/2 items-center justify-center rounded-md bg-muted text-muted-foreground transition hover:text-foreground"
            aria-label="Search"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
        </label>
      </form>

      <div class="text-sm text-muted-foreground">
        Showing {Math.min((currentPage - 1) * pageSize + 1, totalNovels)} - {
          Math.min(currentPage * pageSize, totalNovels)
        } of {totalNovels} novels
      </div>
    </div>

    {
      novels.length > 0 ? (
        <div class="grid gap-4 sm:gap-6 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
          {novels.map((novel) => (
            <a
              href={`/novel/${novel.slug}`}
              class="group relative flex flex-col overflow-hidden rounded-2xl border border-border/70 bg-card shadow-sm transition hover:-translate-y-1 hover:shadow-md"
            >
              <div class="aspect-[2/3] w-full overflow-hidden bg-muted relative">
                <div class="absolute left-2 top-2 z-10">
                  <span
                    class={`inline-flex items-center rounded-full border border-transparent px-2.5 py-0.5 text-[10px] font-semibold lowercase tracking-wider shadow backdrop-blur-sm ${novel.status === "ongoing" ? "bg-chart-4/90 text-zinc-950" : "bg-primary/90 text-primary-foreground"}`}
                  >
                    {novel.status}
                  </span>
                </div>
                {novel.cover ? (
                  <img
                    src={`https://${r2Domain}/${novel.cover}`}
                    alt={novel.title}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center text-muted-foreground">
                    No cover
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col p-4">
                <h3 class="line-clamp-2 text-base font-semibold leading-tight group-hover:text-primary transition-colors">
                  {novel.title}
                </h3>
                <div class="mt-auto pt-3 flex items-center justify-between text-xs text-muted-foreground">
                  <span class="flex items-center gap-1 font-medium bg-muted/50 px-2 py-0.5 rounded-md">
                    {novel.chapterCount} Chapters
                  </span>
                  <span class="flex items-center gap-1">
                    <svg
                      class="h-3.5 w-3.5 text-yellow-500"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    {novel.score.toFixed(1)}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center rounded-3xl border border-dashed border-border/60 py-24 text-center">
          <div class="rounded-full bg-muted/50 p-4">
            <svg
              class="h-8 w-8 text-muted-foreground"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6v6m0 0v6m0-6h6m-6 0H6"
              />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">No novels found</h3>
          <p class="mt-2 text-sm text-muted-foreground max-w-sm">
            {searchQuery
              ? `We couldn't find any novels matching "${searchQuery}". Try adjusting your search.`
              : "There are currently no novels in the library."}
          </p>
          {searchQuery && (
            <a
              href="/novels"
              class="mt-6 inline-flex h-10 items-center justify-center rounded-xl bg-primary px-4 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90"
            >
              Clear search
            </a>
          )}
        </div>
      )
    }

    {
      totalPages > 1 && (
        <div class="mt-12 flex items-center justify-center gap-2">
          <a
            href={getPageUrl(Math.max(1, currentPage - 1))}
            class:list={[
              "inline-flex h-10 items-center justify-center rounded-xl border border-border/70 bg-card px-4 text-sm font-medium transition hover:bg-muted",
              currentPage === 1 && "pointer-events-none opacity-50",
            ]}
          >
            Previous
          </a>
          <div class="text-sm text-muted-foreground mx-4">
            Page{" "}
            <span class="font-semibold text-foreground">{currentPage}</span> of{" "}
            {totalPages}
          </div>
          <a
            href={getPageUrl(Math.min(totalPages, currentPage + 1))}
            class:list={[
              "inline-flex h-10 items-center justify-center rounded-xl border border-border/70 bg-card px-4 text-sm font-medium transition hover:bg-muted",
              currentPage === totalPages && "pointer-events-none opacity-50",
            ]}
          >
            Next
          </a>
        </div>
      )
    }
  </main>
</Layout>
