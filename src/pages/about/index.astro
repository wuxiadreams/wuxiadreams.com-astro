---
import Layout from "@/layouts/layout.astro";
import { Content } from "./_content.md";

const exploreLinks = [
  {
    href: "/novels",
    label: "Novels",
    description: "Browse the full catalog and ongoing series",
  },
  {
    href: "/genres",
    label: "Genres",
    description: "Discover stories by theme and setting",
  },
  {
    href: "/tags",
    label: "Tags",
    description: "Filter and explore with topic tags",
  },
  {
    href: "/rankings",
    label: "Rankings",
    description: "Trending picks and rising titles",
  },
  {
    href: "/authors",
    label: "Authors",
    description: "Find books by your favorite writers",
  },
];
---

<Layout title="About — Wuxia Dreams">
  <main class="w-full px-4 py-12">
    <div
      class="mx-auto max-w-3xl prose dark:prose-invert prose-h1:font-bold prose-h1:text-3xl prose-a:text-primary prose-img:rounded-xl"
    >
      <Content />
    </div>

    <section
      class="mx-auto mt-16 max-w-3xl border-t border-border/60 pt-12"
      aria-labelledby="about-explore-heading"
    >
      <h2
        id="about-explore-heading"
        class="text-center text-lg font-semibold tracking-tight text-foreground"
      >
        Start your journey
      </h2>
      <p
        class="mx-auto mt-2 max-w-md text-center text-sm text-muted-foreground"
      >
        Jump to the main hubs on the site and start your next read.
      </p>
      <ul class="mt-8 grid gap-3 sm:grid-cols-2" role="list">
        {
          exploreLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class="group flex flex-col rounded-xl border border-border/70 bg-card/40 px-4 py-4 shadow-sm ring-1 ring-transparent transition-all hover:border-primary/35 hover:bg-muted/30 hover:ring-primary/15 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
              >
                <span class="font-medium text-foreground group-hover:text-primary">
                  {item.label}
                </span>
                <span class="mt-1 text-sm text-muted-foreground">
                  {item.description}
                </span>
                <span
                  class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-primary opacity-90 group-hover:opacity-100"
                  aria-hidden="true"
                >
                  Go
                  <span class="transition-transform group-hover:translate-x-0.5">
                    →
                  </span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>
