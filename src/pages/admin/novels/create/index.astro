---
import { env } from "cloudflare:workers";
import AdminLayout from "@/layouts/admin-layout.astro";
import CreateNovelForm from "../_components/novel-form";
import { ArrowLeft } from "lucide-react";
import { Button } from "@/components/ui/button";

// Admin check
const user = Astro.locals.user;
const adminEmails = (env.ADMIN_EMAILS ?? "").split(",");
if (!user || !adminEmails.includes(user.email)) {
  return Astro.redirect("/");
}
const r2Domain = env.R2_DOMAIN;
---

<AdminLayout title="新建小说">
  <div class="flex flex-col gap-6">
    <div class="flex items-center gap-4">
      <a href="/admin/novels">
        <Button variant="outline" size="icon" className="h-8 w-8">
          <ArrowLeft className="h-4 w-4" />
          <span class="sr-only">返回列表</span>
        </Button>
      </a>
      <div>
        <h1 class="text-2xl font-bold tracking-tight">新建小说</h1>
        <p class="text-muted-foreground">在平台上创建一篇新的小说</p>
      </div>
    </div>

    <CreateNovelForm r2Domain={r2Domain} client:only="react" />
  </div>
</AdminLayout>
