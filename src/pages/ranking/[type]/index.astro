---
import Layout from "@/layouts/layout.astro";
import RankingSection from "@/components/ranking-section.astro";
import { RankingSkeleton } from "@/components/ranking-skeleton";
import { RANKING_METADATA } from "@/lib/rankings";

const { type } = Astro.params;

if (!type || !RANKING_METADATA[type]) {
  return Astro.redirect("/rankings");
}

const metadata = RANKING_METADATA[type];

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, s-maxage=86400, stale-while-revalidate=60",
);
---

<Layout
  title={`${metadata.title} - Rankings — Wuxia Dreams`}
  description={metadata.description}
>
  <main class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-12">
      <div class="flex items-center gap-4 mb-4">
        <a
          href="/rankings"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-muted/50 text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          <span class="sr-only">Back to Rankings</span>
        </a>
        <h1
          class="text-3xl font-extrabold tracking-tight flex items-center gap-3"
        >
          <span class="text-4xl">{metadata.icon}</span>
          {metadata.title}
        </h1>
      </div>
      <p class="text-lg text-muted-foreground pl-14">
        {metadata.description}. Showing the complete top 100 ranking list.
      </p>
    </div>

    <section
      class="rounded-3xl border border-border/70 bg-linear-to-b from-card/80 to-card/20 p-6 shadow-sm backdrop-blur-xl"
    >
      <RankingSection type={type} limit={100} showHeader={false} server:defer>
        <RankingSkeleton showHeader={false} slot="fallback" />
      </RankingSection>
    </section>
  </main>
</Layout>
