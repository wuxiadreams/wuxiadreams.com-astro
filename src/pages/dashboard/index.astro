---
// src/pages/dashboard.astro
import { auth } from "@lib/auth";
import Layout from "../../layouts/Layout.astro";

// 获取当前请求的 Session
const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

// 如果没登录，直接重定向到登录页
if (!session) {
  return Astro.request.headers.get("referer")?.includes("/login")
    ? null
    : Astro.redirect("/login");
}

const { user } = session;
// 默认给一个头像
const avatarUrl =
  user.image || `https://api.dicebear.com/9.x/adventurer/svg?seed=${user.name}`;
---

<Layout title="江湖大厅 - Wuxia Dreams">
  <main class="dashboard-page">
    <section class="dashboard-card">
      <header class="header">
        <p class="eyebrow">WUXIA DREAMS</p>
        <div class="user-profile">
          <img src={avatarUrl} alt="User Avatar" class="avatar" />
          <div class="user-info">
            <h1>欢迎回来, {user.name}大侠!</h1>
            <p class="email">门派信箱: {user.email}</p>
          </div>
        </div>
      </header>

      <div class="actions">
        <button id="logout-btn" class="logout-btn">退出江湖</button>
      </div>
    </section>
  </main>
</Layout>

<script>
  import { signOut } from "@lib/auth-client";

  const logoutBtn = document.getElementById("logout-btn");

  logoutBtn?.addEventListener("click", async () => {
    // 禁用按钮防止连点
    if (logoutBtn instanceof HTMLButtonElement) {
      logoutBtn.disabled = true;
      logoutBtn.textContent = "正在退出...";
    }

    await signOut({
      fetchOptions: {
        onSuccess: () => {
          window.location.href = "/login";
        },
      },
    });
  });
</script>

<style>
  .dashboard-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 28px;
    background:
      radial-gradient(
        1200px 600px at 5% -5%,
        rgba(255, 208, 112, 0.2),
        transparent 55%
      ),
      radial-gradient(
        900px 500px at 110% 100%,
        rgba(122, 162, 255, 0.22),
        transparent 55%
      ),
      linear-gradient(160deg, #0b1220 0%, #101b32 45%, #0f172a 100%);
  }

  .dashboard-card {
    width: min(100%, 600px);
    border-radius: 20px;
    padding: 40px 36px;
    color: #e2e8f0;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(15, 23, 42, 0.72);
    box-shadow: 0 24px 60px rgba(2, 6, 23, 0.55);
    backdrop-filter: blur(10px);
  }

  .header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 40px;
  }

  .eyebrow {
    margin: 0 0 24px;
    font-size: 12px;
    letter-spacing: 0.24em;
    color: #93c5fd;
  }

  .user-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.8);
    border: 2px solid rgba(147, 197, 253, 0.5);
    box-shadow: 0 0 20px rgba(147, 197, 253, 0.15);
    padding: 4px;
    object-fit: cover;
  }

  h1 {
    margin: 0 0 8px;
    font-size: 28px;
    line-height: 1.2;
    color: #f8fafc;
  }

  .email {
    margin: 0;
    color: #94a3b8;
    font-size: 15px;
  }

  .actions {
    display: flex;
    justify-content: center;
    border-top: 1px solid rgba(148, 163, 184, 0.15);
    padding-top: 32px;
  }

  .logout-btn {
    border: 1px solid rgba(248, 113, 113, 0.4);
    border-radius: 12px;
    padding: 10px 24px;
    font-weight: 600;
    font-size: 15px;
    color: #fca5a5;
    background: rgba(127, 29, 29, 0.15);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .logout-btn:hover:not(:disabled) {
    background: rgba(127, 29, 29, 0.3);
    border-color: rgba(248, 113, 113, 0.6);
    color: #f87171;
  }

  .logout-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
