---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="注册 - Wuxia Dreams">
  <main class="register-page">
    <section class="register-card">
      <p class="eyebrow">WUXIA DREAMS</p>
      <h1 class="text-red-500">创建账号</h1>
      <p class="subtitle">踏入江湖前，先创建你的身份。</p>

      <form id="register-form" class="register-form">
        <label class="field">
          <span>昵称</span>
          <input
            type="text"
            name="name"
            required
            placeholder="输入你的江湖名"
          />
        </label>

        <label class="field">
          <span>邮箱</span>
          <input
            type="email"
            name="email"
            required
            placeholder="name@example.com"
          />
        </label>

        <label class="field">
          <span>密码</span>
          <input
            type="password"
            name="password"
            required
            placeholder="至少 8 位"
          />
        </label>

        <button type="submit" class="submit-btn">立即注册</button>
      </form>

      <p id="message" class="message"></p>
    </section>
  </main>
</Layout>

<script>
  import { signUp } from "@/lib/auth-client";

  const form = document.getElementById("register-form") as HTMLFormElement;
  const message = document.getElementById("message")!;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;
    const name = formData.get("name") as string;

    const { error } = await signUp.email({
      email,
      password,
      name,
      callbackURL: "/dashboard",
    });

    if (error) {
      message.textContent = `错误: ${error.message}`;
      message.className = "message error";
    } else {
      message.textContent = "注册成功！正在跳转...";
      message.className = "message success";
    }
  });
</script>

<style>
  .register-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 28px;
    background:
      radial-gradient(
        1200px 600px at 5% -5%,
        rgba(255, 208, 112, 0.2),
        transparent 55%
      ),
      radial-gradient(
        900px 500px at 110% 100%,
        rgba(122, 162, 255, 0.22),
        transparent 55%
      ),
      linear-gradient(160deg, #0b1220 0%, #101b32 45%, #0f172a 100%);
  }

  .register-card {
    width: min(100%, 460px);
    border-radius: 20px;
    padding: 28px;
    color: #e2e8f0;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(15, 23, 42, 0.72);
    box-shadow: 0 24px 60px rgba(2, 6, 23, 0.55);
    backdrop-filter: blur(10px);
  }

  .eyebrow {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.24em;
    color: #93c5fd;
  }

  h1 {
    margin: 10px 0 8px;
    font-size: 34px;
    line-height: 1.15;
    color: #f8fafc;
  }

  .subtitle {
    margin: 0 0 18px;
    color: #cbd5e1;
  }

  .register-form {
    display: grid;
    gap: 14px;
  }

  .field {
    display: grid;
    gap: 8px;
  }

  .field span {
    font-size: 14px;
    color: #cbd5e1;
  }

  .field input {
    border: 1px solid rgba(100, 116, 139, 0.7);
    border-radius: 12px;
    padding: 11px 12px;
    background: rgba(15, 23, 42, 0.78);
    color: #f8fafc;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .field input::placeholder {
    color: #64748b;
  }

  .field input:focus {
    outline: none;
    border-color: #60a5fa;
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.25);
  }

  .submit-btn {
    margin-top: 4px;
    border: 0;
    border-radius: 12px;
    padding: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #082f49;
    background: linear-gradient(135deg, #fde68a, #93c5fd 58%, #7dd3fc);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      filter 0.15s ease;
  }

  .submit-btn:hover {
    filter: brightness(1.04);
    transform: translateY(-1px);
  }

  .message {
    margin: 14px 0 0;
    font-size: 14px;
    text-align: center;
    min-height: 20px;
    color: #cbd5e1;
  }

  .message.error {
    color: #fca5a5;
  }

  .message.success {
    color: #86efac;
  }
</style>
