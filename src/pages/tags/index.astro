---
import Layout from "@/layouts/layout.astro";
import { env } from "cloudflare:workers";
import { drizzle } from "drizzle-orm/d1";
import { count, eq, and } from "drizzle-orm";
import * as schema from "@/db/schema";

const db = drizzle(env.DB, { schema });

// Fetch all tags and use pre-calculated novelCount
const allTags = await db
  .select({
    id: schema.tag.id,
    name: schema.tag.name,
    slug: schema.tag.slug,
    novelCount: schema.tag.novelCount,
  })
  .from(schema.tag)
  .orderBy(schema.tag.name);

// Group tags by first letter
const tagsByLetter = allTags.reduce(
  (acc, tag) => {
    const letter = tag.name.charAt(0).toUpperCase();
    const validLetter = /[A-Z]/.test(letter) ? letter : "#";
    if (!acc[validLetter]) acc[validLetter] = [];
    acc[validLetter].push(tag);
    return acc;
  },
  {} as Record<string, typeof allTags>,
);

const sortedLetters = Object.keys(tagsByLetter).sort((a, b) => {
  if (a === "#") return 1;
  if (b === "#") return -1;
  return a.localeCompare(b);
});
---

<Layout
  title="All Novel Tags — Wuxia Dreams"
  description="Explore free online novels by different tags."
>
  <main class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight">Tags</h1>
      <p class="mt-2 text-muted-foreground">
        Explore novels by different tags and genres.
      </p>
    </div>

    <div
      class="sticky top-16 z-30 mb-10 -mx-4 overflow-x-auto bg-background/95 px-4 py-3 backdrop-blur border-b border-border/60 sm:mx-0 sm:px-0"
    >
      <div class="flex items-center gap-1.5 min-w-max">
        {
          sortedLetters.map((letter) => (
            <a
              href={`#letter-${letter}`}
              class="flex h-8 w-8 items-center justify-center rounded-lg text-sm font-medium transition hover:bg-muted"
            >
              {letter}
            </a>
          ))
        }
      </div>
    </div>

    {
      sortedLetters.length > 0 ? (
        <div class="grid gap-10">
          {sortedLetters.map((letter) => (
            <section id={`letter-${letter}`} class="scroll-mt-32">
              <h2 class="mb-5 flex items-center gap-4 text-xl font-bold text-muted-foreground">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-muted text-foreground">
                  {letter}
                </span>
                <div class="h-px flex-1 bg-border/60" />
              </h2>

              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                {tagsByLetter[letter].map((tag) => (
                  <a
                    href={`/tag/${tag.slug}`}
                    class="group flex items-center justify-between gap-4 rounded-2xl border border-border/60 bg-card p-4 shadow-sm transition hover:border-primary/50 hover:bg-muted/30 hover:shadow-md"
                  >
                    <div class="flex flex-col min-w-0 flex-1">
                      <span class="font-semibold group-hover:text-primary transition-colors truncate">
                        {tag.name}
                      </span>
                    </div>
                    <div class="flex h-8 min-w-max items-center justify-center rounded-full bg-muted px-2.5 text-xs font-medium text-muted-foreground transition-colors group-hover:bg-primary/10 group-hover:text-primary whitespace-nowrap">
                      {tag.novelCount}{" "}
                      {tag.novelCount === 1 ? "novel" : "novels"}
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center rounded-3xl border border-dashed border-border/60 py-24 text-center">
          <h3 class="text-lg font-semibold">No tags found</h3>
          <p class="mt-2 text-sm text-muted-foreground">
            There are currently no tags in the database.
          </p>
        </div>
      )
    }
  </main>
</Layout>
