---
import Layout from "@layouts/Layout.astro";
---

<Layout title="登录 - Wuxia Dreams">
  <main class="login-page">
    <section class="login-card">
      <p class="eyebrow">WUXIA DREAMS</p>
      <h1>重返江湖</h1>
      <p class="subtitle">欢迎回来，大侠。</p>

      <form id="login-form" class="login-form">
        <label class="field">
          <span>邮箱</span>
          <input
            type="email"
            name="email"
            required
            placeholder="name@example.com"
          />
        </label>

        <label class="field">
          <span>密码</span>
          <input
            type="password"
            name="password"
            required
            placeholder="输入你的密码"
          />
        </label>

        <button type="submit" class="submit-btn">立即登录</button>
      </form>

      <p id="message" class="message"></p>

      <p class="footer-link">
        还没有账号？ <a href="/">去注册</a>
      </p>
    </section>
  </main>
</Layout>

<script>
  // 确保从你的 auth-client 配置文件导入 authClient 实例
  import { authClient } from "@lib/auth-client";

  const form = document.getElementById("login-form") as HTMLFormElement;
  const message = document.getElementById("message")!;
  const submitBtn = form?.querySelector(".submit-btn") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;

    // 1. UI 状态反馈
    message.textContent = "";
    message.className = "message";
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "正在运功..."; // 契合武侠风格
    }

    // 2. 发起登录请求
    try {
      const { error } = await authClient.signIn.email({
        email,
        password,
        callbackURL: "/dashboard",
        fetchOptions: {
          throw: false,
          onError(ctx) {
            // 这里可以通过 ctx.error 拿到详细错误
            console.log("登录失败:", ctx.error);
          },
        },
      });

      // 3. 处理响应
      if (error) {
        if (
          error.status === 401 ||
          error.code === "INVALID_EMAIL_OR_PASSWORD"
        ) {
          message.textContent = "登录失败: 邮箱或密码错误";
        } else {
          message.textContent = `登录失败: ${error.message || "系统开小差了"}`;
        }
        message.className = "message error";

        // 恢复按钮
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = "立即登录";
        }
      } else {
        // 登录成功
        message.textContent = "登录成功！正在进入江湖...";
        message.className = "message success";

        setTimeout(() => {
          window.location.href = "/dashboard";
        }, 1000);
      }
    } catch (err) {
      // 捕获 fetch failed 等底层网络异常
      console.error("请求异常:", err);
      message.textContent = "登录失败: 邮箱或密码错误";
      message.className = "message error";

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "立即登录";
      }
    }
  });
</script>

<style>
  .login-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 28px;
    background:
      radial-gradient(
        1200px 600px at 5% -5%,
        rgba(255, 208, 112, 0.2),
        transparent 55%
      ),
      radial-gradient(
        900px 500px at 110% 100%,
        rgba(122, 162, 255, 0.22),
        transparent 55%
      ),
      linear-gradient(160deg, #0b1220 0%, #101b32 45%, #0f172a 100%);
  }

  .login-card {
    width: min(100%, 420px);
    border-radius: 20px;
    padding: 32px 28px;
    color: #e2e8f0;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(15, 23, 42, 0.72);
    box-shadow: 0 24px 60px rgba(2, 6, 23, 0.55);
    backdrop-filter: blur(10px);
  }

  .eyebrow {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.24em;
    color: #93c5fd;
    text-align: center;
  }

  h1 {
    margin: 10px 0 8px;
    font-size: 34px;
    line-height: 1.15;
    color: #f8fafc;
    text-align: center;
  }

  .subtitle {
    margin: 0 0 24px;
    color: #cbd5e1;
    text-align: center;
  }

  .login-form {
    display: grid;
    gap: 16px;
  }

  .field {
    display: grid;
    gap: 8px;
  }

  .field span {
    font-size: 14px;
    color: #cbd5e1;
  }

  .field input {
    border: 1px solid rgba(100, 116, 139, 0.7);
    border-radius: 12px;
    padding: 11px 12px;
    background: rgba(15, 23, 42, 0.78);
    color: #f8fafc;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .field input::placeholder {
    color: #64748b;
  }

  .field input:focus {
    outline: none;
    border-color: #60a5fa;
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.25);
  }

  .submit-btn {
    margin-top: 8px;
    border: 0;
    border-radius: 12px;
    padding: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #082f49;
    background: linear-gradient(135deg, #fde68a, #93c5fd 58%, #7dd3fc);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      filter 0.15s ease;
  }

  .submit-btn:hover {
    filter: brightness(1.04);
    transform: translateY(-1px);
  }

  .message {
    margin: 14px 0 0;
    font-size: 14px;
    text-align: center;
    min-height: 20px;
    color: #cbd5e1;
  }

  .message.error {
    color: #fca5a5;
  }

  .message.success {
    color: #86efac;
  }

  .footer-link {
    margin: 20px 0 0;
    text-align: center;
    font-size: 14px;
    color: #94a3b8;
  }

  .footer-link a {
    color: #60a5fa;
    text-decoration: none;
    font-weight: 500;
  }

  .footer-link a:hover {
    text-decoration: underline;
  }
</style>
