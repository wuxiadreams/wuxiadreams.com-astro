---
import { ClientRouter } from "astro:transitions";
import Header from "@/components/header.astro";
import Footer from "@/components/footer.astro";
import "@/styles/global.css";

const {
  title = "Wuxia Dreams - Free wuxia, xianxia and light novels reading online",
  description = "Explore Wuxia Dreams for free Wuxia, Xianxia and Light novels. Discover the most popular novels adapted to Cdrama and Kdrama. Dive into popular and top ranking online novels today!",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/logo.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="twitter:site" content="@wuxiadreams" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage.href} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark light" />
    <script is:inline data-astro-rerun>
      function applyTheme() {
        const stored = (() => {
          try {
            return localStorage.getItem("theme");
          } catch {
            return null;
          }
        })();

        const theme =
          stored === "dark" || stored === "light" ? stored : "light";

        const root = document.documentElement;
        root.classList.toggle("dark", theme === "dark");
        root.style.colorScheme = theme;
      }

      // 首次加载运行
      applyTheme();

      // 每次 View Transitions 切换页面后重新运行
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
    <script is:inline data-astro-rerun>
      if (typeof window.setupThemeToggle === "undefined") {
        window.setupThemeToggle = () => {
          function handleThemeClick(e) {
            const btn = e.target.closest("[data-theme-toggle]");
            if (!btn) return;

            const root = document.documentElement;
            const nextIsDark = root.classList.toggle("dark");
            const next = nextIsDark ? "dark" : "light";
            root.style.colorScheme = next;

            try {
              localStorage.setItem("theme", next);
            } catch {}
          }

          document.removeEventListener("click", handleThemeClick);
          document.addEventListener("click", handleThemeClick);
        };
      }

      // 1. 首次加载运行
      window.setupThemeToggle();

      // 2. 每次 View Transitions 切换页面后重新运行
      document.addEventListener("astro:after-swap", window.setupThemeToggle);
    </script>

    <script is:inline id="sharethis-script" type="text/javascript" defer
    ></script>
    <script is:inline>
      function reloadShareThis() {
        const oldScript = document.getElementById("sharethis-script");
        if (oldScript) {
          oldScript.remove();
        }

        window.__sharethis__ = null;
        const container = document.querySelector(".sharethis-share-buttons");
        if (!container) return;

        const newScript = document.createElement("script");
        newScript.id = "sharethis-script";
        newScript.src = "/js/sharethis.min.js";
        newScript.defer = true;

        document.head.appendChild(newScript);
      }

      document.addEventListener("astro:page-load", reloadShareThis);
    </script>
  </head>
  <body>
    <div
      class="min-h-dvh bg-background text-foreground"
      transition:animate="none"
    >
      <Header />
      <slot />
      <Footer />
    </div>
  </body>
</html>
